# ===========================================
# SocialBharat — Environment Variables
# Copy this to .env.local and fill in values
# ===========================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # SERVER ONLY — never expose to client

# ---- Razorpay (India Payments) ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret                 # SERVER ONLY
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret     # SERVER ONLY
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx       # Public key for checkout widget

# ---- Stripe (International Payments) ----
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx                  # SERVER ONLY
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx                # SERVER ONLY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxxxxxxxxxxxx                          # SERVER ONLY

# ---- SMS/OTP (MSG91) ----
MSG91_AUTH_KEY=your-msg91-auth-key                       # SERVER ONLY
MSG91_TEMPLATE_ID=your-msg91-template-id
MSG91_SENDER_ID=SOCBRT

# ---- AI Services ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxx                          # SERVER ONLY

# ---- Social Platform APIs ----
# Meta (Facebook, Instagram, WhatsApp)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret                     # SERVER ONLY
META_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Twitter/X
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret               # SERVER ONLY
TWITTER_BEARER_TOKEN=your-twitter-bearer-token           # SERVER ONLY

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret       # SERVER ONLY

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key                     # SERVER ONLY

# WhatsApp Business
# NOTE: WhatsApp phone_number_id + access_token are user-supplied at runtime
# via POST /api/connectors/whatsapp/connect and stored encrypted per-user in
# social_profiles.access_token_encrypted. They are NOT platform-level env vars.
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# ---- Analytics & Monitoring ----
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxxxxxxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxxxxxxxx

# ---- Rate Limiting (Upstash Redis REST) ----
# Used by src/lib/ratelimit.ts. Stays on Upstash REST even on the VPS
# to avoid an app-code rewrite; self-hosted Redis (below) is for BullMQ.
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token              # SERVER ONLY

# ---- Background jobs (BullMQ, added in V3 Phase 3B) ----
# Self-hosted Redis on the Hostinger VPS; leave empty on Vercel/local if not needed.
REDIS_URL=redis://localhost:6379

# ---- App Configuration ----
NEXT_PUBLIC_APP_URL=https://socialbharat.tynkai.com
NEXT_PUBLIC_APP_NAME=SocialBharat
COMPANY_GST_STATE=Karnataka
COMPANY_GSTIN=your-company-gstin

# ---- Security ----
# 32-byte hex key for AES-256-GCM encryption of stored OAuth tokens (social_profiles.access_token_encrypted)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-char-hex-string          # SERVER ONLY

# Shared secret for VPS crontab → /api/cron/* authenticity check
# See deploy/CRONTAB.md for the curl-based scheduler entries.
CRON_SECRET=replace-with-random-32-char-secret           # SERVER ONLY
